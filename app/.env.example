# ============================================================================
# CLIENT (exposed to the browser — only VITE_* keys)
# ============================================================================
VITE_ZG_RPC=https://evmrpc-testnet.0g.ai
VITE_ZG_CHAIN_ID=16602
VITE_EXPLORER=https://chainscan-galileo.0g.ai
# Deployed AeonINFT address (from contracts deploy output)
VITE_AEON_CONTRACT=
# Leave blank in dev (Vite proxies /api). Set only if the API is on another origin.
VITE_API_BASE=

# ============================================================================
# SERVER (used by the API — NEVER prefix these with VITE_; never sent to client)
# ============================================================================
# 0G Compute Router (chat). Create an app-sk key at https://pc.testnet.0g.ai
ROUTER_BASE=https://router-api-testnet.integratenetwork.work/v1
ROUTER_API_KEY=
ROUTER_MODEL=llama-3.3-70b-instruct

# 0G chain + storage
ZG_RPC=https://evmrpc-testnet.0g.ai
INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# Dedicated testnet wallet that PAYS for storage uploads. Fund it at https://faucet.0g.ai
# (Server only ever uploads ciphertext — it cannot read companion memory.)
STORAGE_PRIVATE_KEY=

# Local dev API port (Vite proxies /api -> this)
API_PORT=8787
